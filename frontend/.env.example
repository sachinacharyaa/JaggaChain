# Backend API
# - Local dev: http://localhost:5000
# - Production (Vercel): https://your-backend-domain.vercel.app
VITE_API_URL=http://localhost:5000

# Solana RPC for wallet transactions (devnet). Default: https://rpc.ankr.com/solana_devnet
# If you see "failed to get recent blockhash" or "Failed to fetch", set a working RPC here.
# VITE_SOLANA_RPC=https://api.devnet.solana.org

# Assigned government wallets (base58). Anyone else is Citizen.
# VITE_WALLET_LRO=sDHAt4Sfn556SXvKddXjCwAeKaMpLHEKKWcfG7hfmoz
# VITE_WALLET_CLRO=8b29vHx8ZdAQp9vNSLSgmNxeqgPZbyqE6paPdwVvXYSB

# Vercel Web Analytics – token from Vercel project settings (optional)
# When set, production builds will send anonymous pageview data to Vercel Analytics.
# VITE_VERCEL_ANALYTICS_TOKEN=
